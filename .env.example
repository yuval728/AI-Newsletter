# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_SEARCH_MODEL=gemini-2.0-flash-exp

# Beehiiv API
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_publication_id_here
BEEHIIV_BASE_URL=https://api.beehiiv.com/v2

# Pollinations (Image Generation)
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# Database
DATABASE_PATH=newsletter.db

# Newsletter Settings
NEWSLETTER_NAME="AI Weekly"
NEWSLETTER_FROM_NAME="AI Weekly Team"
NEWSLETTER_FROM_EMAIL="hello@aiweekly.example.com"
NEWSLETTER_SUBJECT_PREFIX="AI Weekly -"
NEWSLETTER_MAX_ARTICLES=1

# Scheduler
SCHEDULE_TIME_UTC=09:00
TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Development
DRY_RUN=false
DEBUG=false