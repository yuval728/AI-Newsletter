# ============================================
# COPY THIS TO .env AND FILL IN YOUR VALUES
# ============================================

# REQUIRED - Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# REQUIRED - Get from https://app.beehiiv.com/settings/api
BEEHIIV_API_KEY=
PUBLICATION_ID=

# OPTIONAL - Pollinations (free tier works without key)
POLLINATIONS_KEY=

# Database (auto-created)
DATABASE_PATH=data/newsletter.db

# Gemini Settings
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SEARCH_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192

# Beehiiv
BEEHIIV_BASE_URL=https://api.beehiiv.com/v2

# Image Generation
IMAGE_MODEL=gptimage
IMAGE_WIDTH=1200
IMAGE_HEIGHT=630

# Resilience
MAX_RETRIES=3
RETRY_BACKOFF=2.0
REQUEST_TIMEOUT=120

# Publishing
AUTO_PUBLISH=true
DRY_RUN=false

# Newsletter Identity (CHANGE THESE)
NEWSLETTER_NAME=AI Weekly
NEWSLETTER_FROM_NAME=AI Weekly Team
NEWSLETTER_FROM_EMAIL=hello@yourdomain.com
NEWSLETTER_SUBJECT_PREFIX=AI Weekly -
NEWSLETTER_MAX_ARTICLES=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Scheduler
SCHEDULE_TIME_UTC=09:00
TIMEZONE=UTC